// Database schema for the "Drift Happens" segment system.
//
// We grow the schema in lockstep with feature delivery. Day 1 introduces the
// core data: customers, their transactions, segment definitions, and current
// materialized membership. Day 2 will add delta history + the cascade graph.
// Day 3 will add the messaging outbox.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SegmentType {
  // Auto-recomputes when underlying data changes.
  DYNAMIC
  // Frozen at creation; only refreshed by explicit user action.
  STATIC
}

enum DeltaChange {
  ADD
  REMOVE
}

enum OutboxStatus {
  // Written by the orchestrator inside the membership-change transaction;
  // not yet sent to RabbitMQ.
  PENDING
  // Successfully delivered to the broker.
  PUBLISHED
}

model Customer {
  id        String   @id @default(uuid(7))
  email     String   @unique
  name      String

  // Flexible attributes used by segment rules (country, birthYear, loyalty, etc).
  // Application code defines the expected shape via TypeScript types in @drift/shared.
  profile   Json     @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions       Transaction[]
  segmentMemberships SegmentMember[]
  segmentDeltas      SegmentDelta[]
}

model Transaction {
  id         String   @id @default(uuid(7))
  customerId String

  // Decimal, not Float — float arithmetic is unsafe for money.
  amount     Decimal  @db.Decimal(12, 2)

  // When the transaction actually happened (used by segment filters).
  occurredAt DateTime
  // When we ingested the row (lets us distinguish late-arriving data from real activity).
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // The hot query: "transactions for customer X within a time window".
  @@index([customerId, occurredAt])
}

model Segment {
  id          String      @id @default(uuid(7))
  name        String      @unique
  description String?
  type        SegmentType

  // Recursive condition tree (AND/OR + leaf predicates like transaction_count,
  // in_segment, profile match). JSONB because relational modeling of recursive
  // trees is painful, and the tree is read/written atomically as a whole.
  rule        Json

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  members      SegmentMember[]
  deltas       SegmentDelta[]
  // Edges where this segment is the parent — i.e., segments whose change
  // triggers this one to recompute live as my "downstream" via these rows.
  asParent     SegmentDependency[] @relation("Parent")
  // Edges where this segment is the child — i.e., parents I depend on.
  asChild      SegmentDependency[] @relation("Child")
}

// Materialized current membership: "who is in segment X right now".
// Junction table (vs a JSONB array on Segment) so individual memberships are
// indexable and updates are row-level rather than rewriting a large blob.
model SegmentMember {
  segmentId  String
  customerId String
  joinedAt   DateTime @default(now())

  segment  Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@id([segmentId, customerId])
  // Reverse lookup: "which segments is customer Y in?"
  @@index([customerId])
}

// Append-only history of membership changes. Every row records a single
// (segment, customer, ADD|REMOVE) event. Rows from the same evaluation pass
// share a batchId so consumers can fetch a whole "delta event" coherently.
model SegmentDelta {
  id         String      @id @default(uuid(7))
  segmentId  String
  customerId String
  change     DeltaChange
  // UUID stamped onto every delta produced by one evaluation pass.
  // Lets a consumer ask "all changes from this batch" in one query.
  batchId    String
  occurredAt DateTime    @default(now())

  segment  Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Hot query: recent changes for the segment detail page.
  @@index([segmentId, occurredAt])
  // Hot query: "everything that changed in this batch".
  @@index([batchId])
  // Less hot but useful: a customer's full segment history.
  @@index([customerId])
}

// Materialized cascade graph. Edges are extracted from rules' `in_segment`
// predicates at save time so the cascade can lookup "who depends on me?"
// without reparsing every segment's rule at runtime.
//
// Composite PK on (parentId, childId) gives uniqueness AND a usable index for
// the forward query (`WHERE parentId = ?`) via leftmost-prefix.
model SegmentDependency {
  parentId String
  childId  String

  parent Segment @relation("Parent", fields: [parentId], references: [id], onDelete: Cascade)
  child  Segment @relation("Child", fields: [childId], references: [id], onDelete: Cascade)

  @@id([parentId, childId])
}

// Consumer-side dedup record. Each row marks "consumer X has handled
// event Y". Used by consumers with non-idempotent side effects (e.g. the
// campaign consumer that simulates sending notifications) — they try to
// insert before doing the work, and the unique constraint on the
// composite PK rejects duplicates atomically.
//
// The cascade consumer doesn't need this table because its work is
// naturally idempotent: re-evaluating a segment that hasn't changed is a
// no-op via the orchestrator's diff step.
//
// Composite PK on (eventId, consumerName) lets multiple consumers dedup
// the same event independently — the campaign consumer's row never
// blocks an Elasticsearch indexer (or any future consumer) from
// processing the same event.
model ProcessedEvent {
  // The OutboxEvent.id from the wire envelope.
  eventId      String
  // Stable identifier of the consumer (e.g., "campaign-consumer").
  consumerName String
  processedAt  DateTime @default(now())

  @@id([eventId, consumerName])
}

// Transactional outbox. Solves the dual-write problem between Postgres and
// RabbitMQ: the orchestrator inserts a row here in the same transaction
// that updates SegmentMember + SegmentDelta. A separate publisher then
// drains PENDING rows to the broker. If the DB write fails, no event is
// produced; if the DB write succeeds, the event will eventually be delivered
// (at-least-once — consumers must be idempotent).
model OutboxEvent {
  id          String       @id @default(uuid(7))
  // Dot-notation identifier matching the broker's routing key convention,
  // e.g., "segment.delta". String (not enum) so new event types can be
  // introduced without a migration.
  eventType   String
  // The event body as JSONB. Shape depends on eventType; producers and
  // consumers agree on it via @drift/shared types.
  payload     Json
  status      OutboxStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  // Stamped when the publisher successfully delivers to RabbitMQ.
  publishedAt DateTime?

  // Hot query for the publisher: `WHERE status='PENDING' ORDER BY createdAt`.
  // The composite index supports the filter (leftmost prefix on status) and
  // the ordering without an extra sort.
  @@index([status, createdAt])
}
