# Template for apps/api/.env (which is gitignored).
# Copy this file to `.env` in the same directory and adjust values for your environment.

# --- Postgres ---
DATABASE_URL="postgresql://drift:drift@localhost:5432/drift?schema=public"

# --- RabbitMQ ---
RABBITMQ_URL="amqp://drift:drift@localhost:5672"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Elasticsearch ---
ELASTICSEARCH_URL="http://localhost:9200"

# --- API server ---
PORT=3000
