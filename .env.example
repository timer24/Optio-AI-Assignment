# Copy this file to `.env` and adjust values as needed.
# `.env` is gitignored; `.env.example` is committed so other devs know what to set.

# --- Postgres ---
DATABASE_URL=postgresql://drift:drift@localhost:5432/drift?schema=public

# --- RabbitMQ ---
RABBITMQ_URL=amqp://drift:drift@localhost:5672

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://localhost:9200

# --- API ---
API_PORT=3000

# --- Web ---
WEB_PORT=4200
